{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SoulmateStore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=SoulmateStore;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  },
  "Jwt": {
    "Secret": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARS_LONG",
    "Issuer": "SoulmateStore",
    "Audience": "SoulmateStore",
    "AccessTokenExpiresInMinutes": 60,
    "RefreshTokenExpiresInDays": 7,
    "AdminRefreshTokenExpiresInHours": 24
  },
  "InternalApi": {
    "Key": "YOUR_INTERNAL_API_KEY"
  },
  "FrontendUrl": "http://localhost:4200",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4000"
    ]
  },
  "Payment": {
    "VodafoneCashNumber": "010XXXXXXXX",
    "InstaPayNumber": "your-instapay-id",
    "MaxAttempts": 3
  },
  "Cloudinary": {
    "CloudName": "your-cloud-name",
    "ApiKey": "your-api-key",
    "ApiSecret": "your-api-secret"
  },
  "Mail": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "your-email@gmail.com",
    "Password": "your-app-password",
    "From": "Soulmate Store <your-email@gmail.com>"
  },
  "Shipping": {
    "Cost": 50
  },
  "Upload": {
    "MaxFileSizeMB": 5,
    "AllowedExtensions": [ ".jpg", ".png", ".webp" ]
  },
  "OrderExpiration": {
    "PendingHoursLimit": 48
  }
}
