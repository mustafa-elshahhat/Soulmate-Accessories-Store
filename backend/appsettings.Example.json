{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=SoulmateStore;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Secret": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARS_LONG",
    "Issuer": "SoulmateStore",
    "Audience": "SoulmateStore",
    "AccessTokenExpiresInMinutes": 60,
    "RefreshTokenExpiresInDays": 7,
    "AdminRefreshTokenExpiresInHours": 24
  },
  "InternalApi": {
    "Key": "dev-internal-key-change-in-production"
  },
  "FrontendUrl": "http://localhost:4200",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4000"
    ]
  },
  "Payment": {
    "VodafoneCashNumber": "010XXXXXXXX",
    "InstaPayNumber": "your-instapay-id",
    "MaxAttempts": 3
  },
  "Cloudinary": {
    "CloudName": "your-cloud-name",
    "ApiKey": "your-api-key",
    "ApiSecret": "your-api-secret"
  },
  "Mail": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "your-email@gmail.com",
    "Password": "your-app-password",
    "From": "Soulmate Store <your-email@gmail.com>"
  }
}
