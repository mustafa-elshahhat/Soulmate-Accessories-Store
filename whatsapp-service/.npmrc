# Prevent Puppeteer's postinstall hook from downloading Chrome automatically.
# npm exposes this as the npm_config_puppeteer_skip_download env var inside
# lifecycle scripts, which Puppeteer reads with lowest priority. The explicit
# build step (npm run build) sets PUPPETEER_SKIP_DOWNLOAD=false which has
# higher priority and overrides this, so Chrome IS downloaded during the build.
puppeteer_skip_download=true
