# Port for the service
PORT=3001

# URL of the backend API
BACKEND_URL=http://localhost:5291

# Security key for internal requests (Must match backend configuration)
INTERNAL_API_KEY=dev-internal-key-change-in-production

# Enable/Disable pairing UI (/qr and /pair)
ENABLE_WHATSAPP_PAIRING_UI=false

# Admin token for pairing UI access (required if ENABLE_WHATSAPP_PAIRING_UI=true in production)
PAIRING_ADMIN_TOKEN=

# External URL of this service (Used for keep-alive pings on Render)
RENDER_EXTERNAL_URL=

# Node Environment
NODE_ENV=development
